{
  "name": "@stevederico/dotbot",
  "version": "0.40.0",
  "description": "AI agent CLI and library for Node.js — streaming, multi-provider, tool execution, autonomous tasks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dotbot": "./dist/bin/dotbot.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test dist/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "default": "./dist/core/*.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "default": "./dist/tools/*.js"
    },
    "./storage/*": {
      "types": "./dist/storage/*.d.ts",
      "default": "./dist/storage/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/core",
    "dist/storage",
    "dist/tools",
    "dist/utils",
    "dist/bin"
  ],
  "keywords": [
    "ai",
    "agent",
    "llm",
    "anthropic",
    "openai",
    "xai",
    "chatbot",
    "autonomous",
    "tasks",
    "triggers"
  ],
  "author": "Steve Derico",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "typescript": "6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stevederico/dotbot.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
